rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 1. User Profile Collection rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['onboarded', 'selectedCategories', 'currency', 'theme', 'isPremium'])
      );
      allow delete: if false; // Profiles are permanent

      function isValidUserProfile(data) {
        return data.uid == userId
          && data.uid is string
          && (data.email == null || data.email is string)
          && data.isPremium is bool
          && data.onboarded is bool
          && data.createdAt is string;
      }
    }

    // 2. Subscriptions Sub-collection rules
    match /users/{userId}/subscriptions/{subscriptionId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && isValidSubscription(request.resource.data);
      allow update: if isOwner(userId) && isValidSubscription(request.resource.data);

      function isValidSubscription(data) {
        return data.id == subscriptionId
          && data.id is string
          && data.userId == userId
          && data.userId is string
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.amount is number
          && data.billingCycle is string && data.billingCycle in ['weekly', 'monthly', 'quarterly', 'yearly']
          && data.nextChargeDate is string
          && data.isFreeTrial is bool
          && data.reminderTiming is string
          && data.category is string
          && data.status is string && data.status in ['active', 'paused', 'canceled']
          && data.createdAt is string;
      }
    }

    // 3. FCM Tokens Sub-collection rules
    match /users/{userId}/fcmTokens/{tokenId} {
      allow read, write: if isOwner(userId);
    }
  }
}
